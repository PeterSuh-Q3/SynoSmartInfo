#!/bin/bash
#
# SynoSmartInfo start-stop-status
#
# DSM 은 이 스크립트를 root 권한으로 실행한다.
# smart_helper 는 root 데몬으로 기동되어야 하므로 여기서 직접 실행한다.
#

PKG_NAME="Synosmartinfo"
PKG_ROOT="/var/packages/${PKG_NAME}"
HELPER="${PKG_ROOT}/target/bin/smart_helper"
VAR_DIR="${PKG_ROOT}/var"
PID_FILE="${VAR_DIR}/helper.pid"
LOG_FILE="${VAR_DIR}/start-stop.log"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "${LOG_FILE}" 2>/dev/null
}

helper_running() {
    [ -f "${PID_FILE}" ] && kill -0 "$(cat "${PID_FILE}")" 2>/dev/null
}

case "$1" in
start)
    if helper_running; then
        log "smart_helper already running (pid=$(cat "${PID_FILE}"))"
        exit 0
    fi

    if [ ! -f "${HELPER}" ]; then
        log "ERROR: smart_helper not found: ${HELPER}"
        exit 1
    fi

    # VAR_DIR 는 DSM 이 직접 생성·관리하므로 별도 mkdir 불필요
    python3 "${HELPER}" >> "${LOG_FILE}" 2>&1 &
    BGPID=$!
    log "Started smart_helper (pid=${BGPID})"
    # PID 파일은 helper 자신이 기록하지만 기동 실패 감지를 위해 짧게 대기
    sleep 0.5
    if ! kill -0 "${BGPID}" 2>/dev/null; then
        log "ERROR: smart_helper exited immediately"
        exit 1
    fi
    exit 0
    ;;

stop)
    if helper_running; then
        PID="$(cat "${PID_FILE}")"
        kill -TERM "${PID}" 2>/dev/null
        # 최대 5초 대기 후 강제 종료
        for i in $(seq 1 5); do
            kill -0 "${PID}" 2>/dev/null || break
            sleep 1
        done
        kill -0 "${PID}" 2>/dev/null && kill -KILL "${PID}" 2>/dev/null
        log "Stopped smart_helper (pid=${PID})"
    fi
    rm -f "${PID_FILE}" "${VAR_DIR}/helper.sock"
    exit 0
    ;;

status)
    if helper_running; then
        exit 0  # running
    else
        exit 1  # stopped
    fi
    ;;
esac
