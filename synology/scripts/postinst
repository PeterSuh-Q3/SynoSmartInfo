#!/bin/bash
#
# SynoSmartInfo post-installation script
# DSM 은 이 스크립트를 root 권한으로 실행한다.
#

PKG_NAME=$(basename "$SYNOPKG_PKGDEST")
TARGET_DIR="/var/packages/$PKG_NAME/target"
UI_DIR="$TARGET_DIR/ui"
BIN_DIR="$TARGET_DIR/bin"
VAR_DIR="/var/packages/$PKG_NAME/var"
SOCKET_DIR="/var/run/synosmartinfo"

log_message() {
    mkdir -p "$VAR_DIR" 2>/dev/null
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$VAR_DIR/install.log" 2>/dev/null || echo "$1"
}

log_message "Post-installation starting for: $PKG_NAME"

# ── 1. VAR 디렉터리 생성 ───────────────────────────────────────────────
if mkdir -p "$VAR_DIR"; then
    log_message "VAR_DIR ready: $VAR_DIR"
else
    log_message "ERROR: Failed to create VAR_DIR: $VAR_DIR"
    exit 1
fi

# ── 2. 패키지 전용 그룹/사용자 생성 ──────────────────────────────────
# synosmartinfo 그룹이 없으면 생성
if ! getent group synosmartinfo >/dev/null 2>&1; then
    synogroup --add synosmartinfo 2>/dev/null || \
        addgroup synosmartinfo 2>/dev/null || \
        groupadd synosmartinfo 2>/dev/null || true
    log_message "Created group: synosmartinfo"
fi

# synosmartinfo 사용자가 없으면 생성 (no-login shell, 홈 없음)
if ! getent passwd synosmartinfo >/dev/null 2>&1; then
    adduser -S -D -H -G synosmartinfo -s /bin/false synosmartinfo 2>/dev/null || \
        useradd -r -M -s /sbin/nologin -g synosmartinfo synosmartinfo 2>/dev/null || true
    log_message "Created user: synosmartinfo"
fi

# ── 3. Web UI 심볼릭 링크 생성 ────────────────────────────────────────
if ln -sf "/var/packages/$PKG_NAME/target/ui" \
         "/usr/syno/synoman/webman/3rdparty/$PKG_NAME" 2>/dev/null; then
    log_message "Created web interface symlink"
else
    log_message "WARNING: Failed to create web interface symlink"
fi

# ── 5. 결과 파일 디렉터리 (웹에서 정적 파일 제공용) ──────────────────
RESULT_DIR="/usr/syno/synoman/webman/3rdparty/$PKG_NAME/result"
if mkdir -p "$RESULT_DIR"; then
    chmod 755 "$RESULT_DIR"
    log_message "Result directory ready: $RESULT_DIR"
else
    log_message "WARNING: Failed to create result directory: $RESULT_DIR"
fi

# ── 6. 실행 권한 설정 ─────────────────────────────────────────────────
chmod +x "$BIN_DIR/syno_smart_info.sh"  2>/dev/null || true
chmod +x "$BIN_DIR/smart_helper"        2>/dev/null || true
chmod +x "$BIN_DIR/smart_client.py"     2>/dev/null || true
chmod +x "$UI_DIR/api.cgi"              2>/dev/null || true
log_message "Set execute permissions"

# ── 7. VAR 디렉터리 소유권 (로그 파일 쓰기를 위해 그룹 쓰기 허용) ──
chown -R root:synosmartinfo "$VAR_DIR" 2>/dev/null || true
chmod 775 "$VAR_DIR"                    2>/dev/null || true

log_message "Post-installation completed successfully"
exit 0
