#!/bin/bash

# SynoSmartInfo post-installation script (DSM 7 호환, DEBUG MODE)
# DSM은 이 스크립트를 root 권한으로 실행한다.

# ─────────────────────────────────────────────────────────────────────────
# DEBUG: set -x 로 모든 명령 추적, set -e 제거
# ─────────────────────────────────────────────────────────────────────────
set -x   # 모든 명령 실행 전 출력 (디버그 핵심)
# set -e 제거: 오류 발생해도 계속 진행하며 exit code 수집

# 모든 출력을 stderr(DSM 설치 로그에 캡처됨)로 분기
exec 2>&1

# ─────────────────────────────────────────────────────────────────────────
# 상수 및 환경 변수 설정
# ─────────────────────────────────────────────────────────────────────────

PKG_NAME="${SYNOPKG_PKGNAME:-Synosmartinfo}"
TARGET_DIR="/var/packages/$PKG_NAME/target"
UI_DIR="$TARGET_DIR/ui"
BIN_DIR="$TARGET_DIR/bin"
VAR_DIR="/var/packages/$PKG_NAME/var"
SUDOERS_FILE="/etc/sudoers.d/$PKG_NAME"
RESULT_DIR="/usr/syno/synoman/webman/3rdparty/$PKG_NAME/result"
LOG_FILE="$VAR_DIR/install.log"

# ─────────────────────────────────────────────────────────────────────────
# 로그 함수: 파일 + stderr 동시 출력
# ─────────────────────────────────────────────────────────────────────────
log() {
  local level="$1"
  local msg="$2"
  local ts
  ts="$(date '+%Y-%m-%d %H:%M:%S')"
  local line="[$ts] [$level] $msg"
  echo "$line" >&2
  echo "$line" >> "$LOG_FILE" 2>/dev/null || true
}

dbg() { log "DEBUG" "$1"; }
inf() { log "INFO"  "$1"; }
wrn() { log "WARN"  "$1"; }
err() { log "ERROR" "$1"; }

# ─────────────────────────────────────────────────────────────────────────
# 실패 추적 변수
# ─────────────────────────────────────────────────────────────────────────
FAIL=0
fail_step() {
  local step="$1"
  local rc="$2"
  err "STEP FAILED: $step (exit=$rc)"
  FAIL=$((FAIL + 1))
}

# ─────────────────────────────────────────────────────────────────────────
# STEP 0: 환경 진단
# ─────────────────────────────────────────────────────────────────────────
inf "=== POST-INSTALL START: $PKG_NAME ==="
dbg "WHOAMI      : $(whoami 2>&1)"
dbg "UID/GID     : $(id 2>&1)"
dbg "SYNOPKG_*   : PKGNAME=${SYNOPKG_PKGNAME:-UNSET} PKGDEST=${SYNOPKG_PKGDEST:-UNSET}"
dbg "TARGET_DIR  : $TARGET_DIR  exists=$([ -d "$TARGET_DIR" ] && echo YES || echo NO)"
dbg "BIN_DIR     : $BIN_DIR     exists=$([ -d "$BIN_DIR" ] && echo YES || echo NO)"
dbg "UI_DIR      : $UI_DIR      exists=$([ -d "$UI_DIR" ] && echo YES || echo NO)"
dbg "VAR_DIR     : $VAR_DIR     exists=$([ -d "$VAR_DIR" ] && echo YES || echo NO)"
dbg "SUDOERS_DIR : /etc/sudoers.d exists=$([ -d /etc/sudoers.d ] && echo YES || echo NO)"
dbg "RESULT_DIR  : $RESULT_DIR  exists=$([ -d "$RESULT_DIR" ] && echo YES || echo NO)"
dbg "--- TARGET tree ---"
ls -la "$TARGET_DIR" 2>&1 || dbg "(TARGET_DIR not found)"
dbg "--- BIN_DIR tree ---"
ls -la "$BIN_DIR" 2>&1 || dbg "(BIN_DIR not found)"

# ─────────────────────────────────────────────────────────────────────────
# STEP 1: VAR 디렉터리 생성
# ─────────────────────────────────────────────────────────────────────────
inf "--- STEP 1: Create VAR_DIR ---"
mkdir -p "$VAR_DIR" 2>&1; rc=$?
dbg "mkdir VAR_DIR rc=$rc"
[ $rc -ne 0 ] && fail_step "mkdir VAR_DIR" $rc

chmod 775 "$VAR_DIR" 2>&1; rc=$?
dbg "chmod 775 VAR_DIR rc=$rc"
[ $rc -ne 0 ] && fail_step "chmod VAR_DIR" $rc

dbg "VAR_DIR stat: $(stat "$VAR_DIR" 2>&1)"
inf "STEP 1 done"

# ─────────────────────────────────────────────────────────────────────────
# STEP 2: sudoers 설정
# ─────────────────────────────────────────────────────────────────────────
inf "--- STEP 2: Configure sudoers ---"

SMART_SCRIPT="$BIN_DIR/syno_smart_info.sh"
dbg "SMART_SCRIPT path: $SMART_SCRIPT"
dbg "SMART_SCRIPT exists: $([ -f "$SMART_SCRIPT" ] && echo YES || echo NO)"

if [ -f "$SMART_SCRIPT" ]; then
  SUDOERS_LINE="synosmartinfo ALL=(root) NOPASSWD: $SMART_SCRIPT"
  inf "SMART script found → sudoers line set"
else
  SUDOERS_LINE="# SMART_SCRIPT not found at install time: $SMART_SCRIPT"
  wrn "SMART script NOT found → placeholder comment in sudoers"
fi

dbg "SUDOERS_LINE: $SUDOERS_LINE"
dbg "SUDOERS_FILE: $SUDOERS_FILE"
dbg "SUDOERS_TMP : ${SUDOERS_FILE}.tmp"

# sudoers.d 존재 확인
if [ ! -d "/etc/sudoers.d" ]; then
  err "/etc/sudoers.d missing — cannot create sudoers"
  fail_step "sudoers.d check" 1
else
  dbg "/etc/sudoers.d stat: $(ls -la /etc/sudoers.d 2>&1)"

  # 기존 백업
  if [ -f "$SUDOERS_FILE" ]; then
    BACKUP="${SUDOERS_FILE}.backup.$(date +%s)"
    mv "$SUDOERS_FILE" "$BACKUP" 2>&1; rc=$?
    dbg "backup mv rc=$rc → $BACKUP"
  fi

  # tmp 파일 생성 (printf 사용, heredoc 회피)
  SUDOERS_TMP="${SUDOERS_FILE}.tmp"
  dbg "Writing tmp file: $SUDOERS_TMP"

  printf '%s\n' \
    "#" \
    "# SynoSmartInfo - Narrow sudoers (auto-generated)" \
    "# Generated: $(date '+%Y-%m-%d %H:%M:%S')" \
    "# Purpose: Allow SMART script execution only" \
    "#" \
    "$SUDOERS_LINE" \
    > "$SUDOERS_TMP" 2>&1
  rc=$?
  dbg "printf to tmp rc=$rc"

  if [ $rc -ne 0 ] || [ ! -f "$SUDOERS_TMP" ]; then
    err "Failed to write SUDOERS_TMP (rc=$rc, exists=$([ -f "$SUDOERS_TMP" ] && echo YES || echo NO))"
    fail_step "write sudoers.tmp" $rc
  else
    dbg "SUDOERS_TMP content:"
    cat "$SUDOERS_TMP" >&2

    mv "$SUDOERS_TMP" "$SUDOERS_FILE" 2>&1; rc=$?
    dbg "mv tmp→sudoers rc=$rc"
    [ $rc -ne 0 ] && fail_step "mv sudoers.tmp" $rc

    chmod 0440 "$SUDOERS_FILE" 2>&1; rc=$?
    dbg "chmod 0440 sudoers rc=$rc"

    chown root:root "$SUDOERS_FILE" 2>&1; rc=$?
    dbg "chown root:root sudoers rc=$rc"

    if visudo -cf "$SUDOERS_FILE" 2>&1; then
      inf "visudo syntax OK"
    else
      wrn "visudo syntax check FAILED (non-fatal)"
    fi
  fi
fi
inf "STEP 2 done"

# ─────────────────────────────────────────────────────────────────────────
# STEP 3: Web UI 심볼릭 링크
# ─────────────────────────────────────────────────────────────────────────
inf "--- STEP 3: Web UI symlink ---"
WEBMAN_DIR="/usr/syno/synoman/webman/3rdparty/$PKG_NAME"
dbg "UI_DIR   : $UI_DIR  exists=$([ -d "$UI_DIR" ] && echo YES || echo NO)"
dbg "WEBMAN   : $WEBMAN_DIR  exists=$([ -e "$WEBMAN_DIR" ] && echo YES || echo NO)"

if [ -d "$UI_DIR" ]; then
  ln -sf "$UI_DIR" "$WEBMAN_DIR" 2>&1; rc=$?
  dbg "ln -sf rc=$rc"
  [ $rc -ne 0 ] && wrn "symlink failed rc=$rc (may already exist)"
  inf "symlink: $WEBMAN_DIR → $UI_DIR"
else
  wrn "UI_DIR not found — skipping symlink"
fi
inf "STEP 3 done"

# ─────────────────────────────────────────────────────────────────────────
# STEP 4: 결과 파일 디렉터리
# ─────────────────────────────────────────────────────────────────────────
inf "--- STEP 4: Result directory ---"
mkdir -p "$RESULT_DIR" 2>&1; rc=$?
dbg "mkdir RESULT_DIR rc=$rc"
chmod 755 "$RESULT_DIR" 2>&1; rc=$?
dbg "chmod RESULT_DIR rc=$rc"
inf "STEP 4 done"

# ─────────────────────────────────────────────────────────────────────────
# STEP 5: 실행 권한
# ─────────────────────────────────────────────────────────────────────────
inf "--- STEP 5: Set execute permissions ---"
for f in "$UI_DIR/api.cgi" "$BIN_DIR/syno_smart_info.sh"; do
  if [ -f "$f" ]; then
    chmod +x "$f" 2>&1; rc=$?
    dbg "chmod +x $f rc=$rc"
  else
    dbg "SKIP (not found): $f"
  fi
done
inf "STEP 5 done"

# ─────────────────────────────────────────────────────────────────────────
# FINAL
# ─────────────────────────────────────────────────────────────────────────
inf "=== POST-INSTALL COMPLETE: FAIL_COUNT=$FAIL ==="

[ "$FAIL" -gt 0 ] && exit 1 || exit 0
