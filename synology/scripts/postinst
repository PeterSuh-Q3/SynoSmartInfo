#!/bin/bash

# SynoSmartInfo post-installation script (DSM 7 호환, privilege.json 제거)
# DSM은 이 스크립트를 root 권한으로 실행한다.

set -e  # 첫 번째 오류에서 중단

# ─────────────────────────────────────────────────────────────────────────
# 상수 및 환경 변수 설정
# ─────────────────────────────────────────────────────────────────────────

readonly PKG_NAME="${SYNOPKG_PKGNAME:-Synosmartinfo}"
readonly TARGET_DIR="/var/packages/$PKG_NAME/target"
readonly UI_DIR="$TARGET_DIR/ui"
readonly BIN_DIR="$TARGET_DIR/bin"
readonly VAR_DIR="/var/packages/$PKG_NAME/var"
readonly SUDOERS_FILE="/etc/sudoers.d/$PKG_NAME"
readonly RESULT_DIR="/usr/syno/synoman/webman/3rdparty/$PKG_NAME/result"
readonly LOG_FILE="$VAR_DIR/install.log"

# 로그 함수 (디렉터리 생성 후 기록)
log_message() {
  local msg="$1"
  local level="${2:-INFO}"
  mkdir -p "$VAR_DIR" 2>/dev/null || true
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] [$level] $msg" >> "$LOG_FILE" 2>/dev/null || \
  echo "[$level] $msg" >&2
}

log_message "=== Post-installation STARTING for: $PKG_NAME ==="

# ─────────────────────────────────────────────────────────────────────────
# 1. VAR 디렉터리 생성 (로그 저장용)
# ─────────────────────────────────────────────────────────────────────────

if ! mkdir -p "$VAR_DIR" 2>/dev/null; then
  echo "ERROR: Cannot create $VAR_DIR" >&2
  exit 1
fi
chmod 775 "$VAR_DIR"  # DSM이 자동 소유권 관리하므로 chown 불필요
log_message "VAR_DIR ready: $VAR_DIR"

# ─────────────────────────────────────────────────────────────────────────
# 2. 그룹/사용자 생성 생략 (privilege.json이 DSM 자동 처리)
# ─────────────────────────────────────────────────────────────────────────

log_message "Skipping manual group/user creation (DSM privilege.json handles it)"

# ─────────────────────────────────────────────────────────────────────────
# 3. Narrow sudoers 설정 (Narrow Privilege)
# ─────────────────────────────────────────────────────────────────────────

log_message "Configuring narrow sudoers: $SUDOERS_FILE"

# SMART 스크립트 경로 확인
SMART_SCRIPT="$BIN_DIR/syno_smart_info.sh"
if [ ! -f "$SMART_SCRIPT" ]; then
  log_message "WARNING: SMART script not found: $SMART_SCRIPT"
  SMART_SCRIPT=""
fi

# sudoers.d 디렉터리 확인
if [ ! -d "/etc/sudoers.d" ]; then
  log_message "ERROR: /etc/sudoers.d directory missing"
  exit 1
fi

# 기존 파일 백업
if [ -f "$SUDOERS_FILE" ]; then
  mv "$SUDOERS_FILE" "${SUDOERS_FILE}.backup.$(date +%s)" 2>/dev/null || true
  log_message "Backed up existing sudoers file"
fi

# sudoers 내용 생성 (tmp 파일로 안전하게)
cat > "${SUDOERS_FILE}.tmp" << EOF
#
# SynoSmartInfo - Narrow sudoers (auto-generated)
# Generated: $(date '+%Y-%m-%d %H:%M:%S')
# Purpose: Allow SMART script execution only (NO NOPASSWD: ALL)
#

# DSM privilege.json이 synosmartinfo 계정 자동 생성
# synosmartinfo → root으로 SMART 스크립트만 실행 허용
$( [ -n "$SMART_SCRIPT" ] && echo "synosmartinfo ALL=(root) NOPASSWD: $SMART_SCRIPT" || echo "# SMART_SCRIPT not found - no sudoers entry" )
EOF

if [ -f "${SUDOERS_FILE}.tmp" ]; then
  mv "${SUDOERS_FILE}.tmp" "$SUDOERS_FILE"
  chmod 0440 "$SUDOERS_FILE"
  chown root:root "$SUDOERS_FILE"
  log_message "Narrow sudoers created successfully: $SUDOERS_FILE"
  
  # sudoers syntax 검증
  if visudo -cf "$SUDOERS_FILE" >/dev/null 2>&1; then
    log_message "Sudoers syntax verified OK"
  else
    log_message "WARNING: Sudoers syntax check failed"
  fi
else
  log_message "ERROR: Failed to create sudoers file"
  exit 1
fi

# ─────────────────────────────────────────────────────────────────────────
# 4. Web UI 심볼릭 링크 생성
# ─────────────────────────────────────────────────────────────────────────

WEBMAN_DIR="/usr/syno/synoman/webman/3rdparty/$PKG_NAME"
if [ -d "$UI_DIR" ] && ln -sf "$UI_DIR" "$WEBMAN_DIR" 2>/dev/null; then
  log_message "Created web UI symlink: $WEBMAN_DIR -> $UI_DIR"
else
  log_message "WARNING: Failed to create web UI symlink (may already exist)"
fi

# ─────────────────────────────────────────────────────────────────────────
# 5. 결과 파일 디렉터리 생성
# ─────────────────────────────────────────────────────────────────────────

if mkdir -p "$RESULT_DIR" 2>/dev/null; then
  chmod 755 "$RESULT_DIR"
  # chown nobody:nogroup 생략 (DSM Btrfs 제한)
  log_message "Result directory ready: $RESULT_DIR"
else
  log_message "WARNING: Failed to create result directory"
fi

# ─────────────────────────────────────────────────────────────────────────
# 6. 실행 권한 설정
# ─────────────────────────────────────────────────────────────────────────

[ -f "$UI_DIR/api.cgi" ] && chmod +x "$UI_DIR/api.cgi" && log_message "Set +x: api.cgi"
[ -f "$BIN_DIR/syno_smart_info.sh" ] && chmod +x "$BIN_DIR/syno_smart_info.sh" && log_message "Set +x: syno_smart_info.sh"

# ─────────────────────────────────────────────────────────────────────────
# 7. 최종 상태 확인 (chown 완전 제거)
# ─────────────────────────────────────────────────────────────────────────

log_message "=== Post-installation COMPLETED successfully ==="
log_message "PKG_NAME: $PKG_NAME"
log_message "VAR_DIR: $VAR_DIR (DSM auto-management)"
log_message "SUDOERS: $SUDOERS_FILE"
log_message "WEBMAN: $WEBMAN_DIR"

echo "Installation log saved to: $LOG_FILE"
tail -n 10 "$LOG_FILE"

exit 0
